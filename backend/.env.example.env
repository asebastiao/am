# ── Django ────────────────────────────────────────────────────────────────────
# DEBUG=True apenas em desenvolvimento local. NUNCA True em produção.
DEBUG=True

# Gere uma chave nova para produção, por exemplo:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Em produção (DEBUG=False) é obrigatório, ex: "meusite.com,www.meusite.com"
ALLOWED_HOSTS=

# URL do site em produção, ex: https://meusite.com
FRONTEND_URL=

# Origens extra confiáveis para o CSRF (separadas por vírgula), ex: https://meusite.com
CSRF_TRUSTED_ORIGINS=

# Origens CORS extra além do FRONTEND_URL (separadas por vírgula), se necessário
EXTRA_CORS_ORIGINS=

# Limite de tamanho de upload em MB (aplica-se a imagens enviadas no Django Admin)
MAX_UPLOAD_SIZE_MB=10

# ── Cloudinary (armazenamento de imagens) ──────────────────────────────────────
# Obrigatório em produção. Crie uma conta grátis em https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (descomente e preencha para activar envio automático) ───────────────
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=app-password-aqui
# CONTACT_NOTIFY_EMAIL=
